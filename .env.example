# GitHub Personal Access Token (needs repo scope for CI rerun)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# Slack Bot Token (xoxb-...)
SLACK_BOT_TOKEN=xoxb-xxxxxxxxxxxx

# Slack App Token for Socket Mode (xapp-...)
SLACK_APP_TOKEN=xapp-xxxxxxxxxxxx

# Slack channel IDs
SLACK_PR_CHANNEL=C0123456789
SLACK_CI_CHANNEL=C0123456789

# GitHub repo (owner/name)
GITHUB_REPO=sgl-project/sglang

# Polling intervals (seconds)
PR_POLL_INTERVAL=60

# Database path
DB_PATH=data/sgldhelper.db

# Log level and directory
LOG_LEVEL=INFO
LOG_DIR=logs

# AI / Kimi K2.5 (required)
MOONSHOT_API_KEY=sk-xxxxxxxxxxxx
KIMI_BASE_URL=https://api.moonshot.ai/v1
KIMI_MODEL=kimi-k2.5

# AI rate limits
AI_RATE_LIMIT_RPM=10
AI_USER_COOLDOWN_SECONDS=60
AI_USER_COOLDOWN_MAX=5

# Cold start: max PRs to fetch when classification cache is empty
COLD_START_MAX_PRS=500

# Diffusion PR summary interval (seconds), default 2 hours
DIFFUSION_SUMMARY_INTERVAL=7200

# CI monitoring
CI_POLL_INTERVAL=300
CI_MAX_RETRIES=3
CI_HIGH_PRIORITY_MAX_RETRIES=10
CI_HIGH_PRIORITY_LABEL=high-priority
CI_HIGH_PRIORITY_PING_USER=mickqian
CI_OWNER_RERUN_MAX_RETRIES=5
CI_NVIDIA_WORKFLOW_ID=115218617
CI_AMD_WORKFLOW_ID=119055250

# Auto merge
AUTO_MERGE_ENABLED=true
AUTO_MERGE_DELAY_SECONDS=300

# Tracked PR summary interval (seconds), default 12 hours
TRACKED_PR_SUMMARY_INTERVAL=43200

# PR health check interval (seconds), default 2 hours
PR_HEALTH_CHECK_INTERVAL=7200
